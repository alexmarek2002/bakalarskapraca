             RowBox[{"Darker", "@", "Green"}], ",", 
             RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
             RowBox[{"Point", "[", "Sopt", "]"}], ",", 
             RowBox[{"Darker", "@", "Green"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<S*\>\"", ",", "Sopt", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1.5"}], ",", 
                 RowBox[{"-", "1.5"}]}], "}"}]}], "]"}], ",", "Black", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"Apt", ",", "Sopt"}], "}"}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<AS\>\"", ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"Apt", "+", "Sopt"}], ")"}], "/", "2"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", "Black", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"Bpt", ",", "Sopt"}], "}"}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<BS\>\"", ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"Bpt", "+", "Sopt"}], ")"}], "/", "2"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "1"}]}], "}"}]}], "]"}], ",", "Black", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"Cpt", ",", "Sopt"}], "}"}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<CS\>\"", ",", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"Cpt", "+", "Sopt"}], ")"}], "/", "2"}], ",", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "}"}], ",", 
           RowBox[{"PlotRange", "->", "All"}], ",", 
           RowBox[{"Axes", "->", "True"}]}], "\n", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"<|", 
