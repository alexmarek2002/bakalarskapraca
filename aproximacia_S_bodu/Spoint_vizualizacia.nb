          RowBox[{"\"\<c\>\"", "->", "c"}], ",", 
          RowBox[{"\"\<l\>\"", "->", "l"}], ",", " ", 
          RowBox[{"\"\<plot\>\"", "->", "plot"}]}], "|>"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
