          RowBox[{"\"\<mid\>\"", "->", "mid"}], ",", 
          RowBox[{"\"\<proj\>\"", "->", "Rproj"}], ",", 
          RowBox[{"\"\<x*\>\"", "->", "xsol"}], ",", 
          RowBox[{"\"\<S*\>\"", "->", "Sopt"}], ",", 
          RowBox[{"\"\<Lmin\>\"", "->", "Lmin"}], ",", 
