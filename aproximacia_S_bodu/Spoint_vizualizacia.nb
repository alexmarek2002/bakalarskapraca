Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"AxisMin", "[", 
      RowBox[{"P_", ",", "Q_", ",", "R_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "mid", ",", "v", ",", "n", ",", "t", ",", "Rproj", ",", "a", ",", "c",
          ",", "l", ",", "Lfun", ",", "xsol", ",", "dir", ",", "Sopt", ",", 
         "Lmin"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"mid", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"P", "+", "Q"}], ")"}], "/", "2"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"v", "=", 
         RowBox[{"Q", "-", "P"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"v", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ",", 
           RowBox[{"v", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"t", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"R", "-", "mid"}], ")"}], ".", "n"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"n", ".", "n"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Rproj", "=", 
         RowBox[{"mid", "+", 
          RowBox[{"t", "*", "n"}]}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"a", "=", 
         RowBox[{"Norm", "[", 
          RowBox[{"P", "-", "mid"}], "]"}]}], ";", 
        RowBox[{"c", "=", 
         RowBox[{"Norm", "[", 
          RowBox[{"R", "-", "Rproj"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"l", "=", 
         RowBox[{"Norm", "[", 
          RowBox[{"Rproj", "-", "mid"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Lfun", "[", "x_", "]"}], ":=", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"a", "^", "2"}], "+", 
             RowBox[{"x", "^", "2"}]}], "]"}]}], "+", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"c", "^", "2"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"l", "-", "x"}], ")"}], "^", "2"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"xsol", "=", 
         RowBox[{"NArgMin", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Lfun", "[", "x", "]"}], ",", 
             RowBox[{"0", "<=", "x", "<=", "l"}]}], "}"}], ",", "x"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"dir", "=", 
         RowBox[{"Normalize", "[", 
          RowBox[{"Rproj", "-", "mid"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Sopt", "=", 
         RowBox[{"mid", "+", 
          RowBox[{"xsol", "*", "dir"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Lmin", "=", 
         RowBox[{"Lfun", "[", "xsol", "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"plot", "=", 
         RowBox[{"Graphics", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"Red", ",", 
             RowBox[{"PointSize", "[", "0.015", "]"}], ",", 
             RowBox[{"Point", "[", 
              RowBox[{"{", 
               RowBox[{"Apt", ",", "Bpt", ",", "Cpt"}], "}"}], "]"}], ",", 
             "Black", ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<A\>\"", ",", "Apt", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1.5"}], ",", 
                 RowBox[{"-", "1.5"}]}], "}"}]}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<B\>\"", ",", "Bpt", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1.5"}], ",", 
                 RowBox[{"-", "1.5"}]}], "}"}]}], "]"}], ",", 
             RowBox[{"Text", "[", 
              RowBox[{"\"\<C\>\"", ",", "Cpt", ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"-", "1.5"}], ",", 
                 RowBox[{"-", "1.5"}]}], "}"}]}], "]"}], ",", "Black", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"P", ",", "Q"}], "}"}], "]"}], ",", "Dashed", ",", 
             "Blue", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"mid", ",", "Rproj"}], "}"}], "]"}], ",", "Dashed", 
             ",", "Green", ",", 
             RowBox[{"Line", "[", 
              RowBox[{"{", 
               RowBox[{"Rproj", ",", "R"}], "}"}], "]"}], ",", "Purple", ",", 
             RowBox[{"PointSize", "[", "0.015", "]"}], ",", 
